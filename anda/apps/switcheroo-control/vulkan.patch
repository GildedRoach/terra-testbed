diff --git a/src/discrete-detection/vulkan.c b/src/discrete-detection/vulkan.c
new file mode 100644
index 0000000..e845f31
--- /dev/null
+++ b/src/discrete-detection/vulkan.c
@@ -0,0 +1,166 @@
+#include <fcntl.h>
+#include <stdlib.h>
+#include <locale.h>
+#include <sys/sysmacros.h>
+#include <gio/gio.h>
+#include <gudev/gudev.h>
+#include <glib.h>
+#include <glib/gstdio.h>
+#include <vulkan/vulkan.h>
+
+static void
+destroyInstance (VkInstance instance)
+{
+	vkDestroyInstance(instance, NULL);
+}
+G_DEFINE_AUTO_CLEANUP_FREE_FUNC(VkInstance, destroyInstance, NULL);
+
+static gboolean
+has_drm_extension (VkPhysicalDevice device)
+{
+	g_autofree VkExtensionProperties* available_extensions = NULL;
+	uint32_t extension_count = 0;
+
+	vkEnumerateDeviceExtensionProperties (device, NULL, &extension_count, NULL);
+
+	available_extensions = g_malloc (sizeof(VkLayerProperties) * extension_count);
+
+	vkEnumerateDeviceExtensionProperties (device, NULL, &extension_count, available_extensions);
+
+	for (uint32_t i = 0; i < extension_count; ++i) {
+		if (!strcmp(available_extensions[i].extensionName, "VK_EXT_physical_device_drm"))
+			return TRUE;
+	}
+
+	return FALSE;
+
+}
+
+static int
+check_vulkan_device (int fd)
+{
+	g_auto(VkInstance) instance = NULL;
+	VkApplicationInfo app_info;
+	VkInstanceCreateInfo create_info;
+	g_autofree VkPhysicalDevice *devices = NULL;
+	uint32_t device_count = 0;
+	VkPhysicalDeviceDrmPropertiesEXT drm_properties;
+	VkPhysicalDeviceProperties2 device_properties;
+	int64_t expected_major, expected_minor;
+	struct stat st;
+	gboolean found_device;
+
+	if (fstat(fd, &st) != 0)
+		return 0;
+
+	if (!S_ISCHR(st.st_mode))
+		return 0;
+
+	expected_major = major(st.st_rdev);
+	expected_minor = minor(st.st_rdev);
+
+	printf("major = %lu\n", expected_major);
+	printf("minor = %lu\n", expected_minor);
+
+	memset(&app_info, 0, sizeof(app_info));
+	memset(&create_info, 0, sizeof(create_info));
+
+	app_info.sType = VK_STRUCTURE_TYPE_APPLICATION_INFO;
+	app_info.applicationVersion = VK_MAKE_VERSION(1, 0, 0);
+	app_info.engineVersion = VK_MAKE_VERSION(1, 0, 0);
+	app_info.apiVersion = VK_API_VERSION_1_1;
+
+	create_info.sType = VK_STRUCTURE_TYPE_INSTANCE_CREATE_INFO;
+	create_info.pApplicationInfo = &app_info;
+	create_info.enabledExtensionCount = 0;
+	create_info.enabledLayerCount = 0;
+
+	VkResult result = vkCreateInstance (&create_info, NULL, &instance);
+	if (result != VK_SUCCESS) {
+		g_printerr ("Failed to create a vulkan instance (%i)\n", result);
+		return 0;
+	}
+
+	vkEnumeratePhysicalDevices (instance, &device_count, NULL);
+
+	if (device_count == 0)
+		return 0;
+
+	devices = g_malloc (sizeof(VkPhysicalDevice) * device_count);
+	vkEnumeratePhysicalDevices (instance, &device_count, devices);
+
+	for (uint32_t i = 0; i < device_count; ++i) {
+		found_device = FALSE;
+
+		if (!has_drm_extension (devices[i]))
+			continue;
+
+		printf("has extension\n");
+
+		memset(&drm_properties, 0, sizeof(drm_properties));
+		memset(&device_properties, 0, sizeof(device_properties));
+
+		drm_properties.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_DRM_PROPERTIES_EXT;
+		device_properties.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_PROPERTIES_2;
+		device_properties.pNext = &drm_properties;
+
+		vkGetPhysicalDeviceProperties2 (devices[i], &device_properties);
+
+		if (drm_properties.hasPrimary == VK_TRUE) {
+			printf("primary major = %lu\n", drm_properties.primaryMajor);
+			printf("primary minor = %lu\n", drm_properties.primaryMinor);
+
+			if (drm_properties.primaryMajor == expected_major && drm_properties.primaryMinor == expected_minor)
+				found_device = TRUE;
+		}
+
+		if (!found_device && drm_properties.hasRender == VK_TRUE) {
+			printf("render major = %lu\n", drm_properties.renderMajor);
+			printf("render minor = %lu\n", drm_properties.renderMinor);
+
+			if (drm_properties.renderMajor == expected_major && drm_properties.renderMinor == expected_minor)
+				found_device = TRUE;
+		}
+
+		if (found_device) {
+			if (device_properties.properties.deviceType == VK_PHYSICAL_DEVICE_TYPE_DISCRETE_GPU)
+				return 1;
+			else
+				return 0;
+		}
+	}
+
+	return 0;
+}
+
+int main (int argc, char **argv)
+{
+	const char *devname;
+	g_autofd int fd = -1;
+	g_autoptr(GOptionContext) option_context = NULL;
+	g_autoptr(GError) error = NULL;
+
+	setlocale (LC_ALL, "");
+	option_context = g_option_context_new ("");
+
+	if (!g_option_context_parse (option_context, &argc, &argv, &error)) {
+		g_printerr ("Failed to parse arguments: %s\n", error->message);
+		return EXIT_FAILURE;
+	}
+
+	if (argc < 2) {
+		g_printerr ("%s\n", g_option_context_get_help (option_context, TRUE, NULL));
+		return EXIT_FAILURE;
+	}
+	devname = argv[1];
+
+	fd = open (devname, O_RDWR);
+	if (fd < 0)
+		return EXIT_FAILURE;
+	printf("Opened device\n");
+
+	if (check_vulkan_device (fd))
+		return EXIT_SUCCESS;
+
+	return EXIT_FAILURE;
+}
\ No newline at end of file
diff --git a/tests/discrete-detection/meson.build b/tests/discrete-detection/meson.build
index 69ad340..e90e522 100644
--- a/tests/discrete-detection/meson.build
+++ b/tests/discrete-detection/meson.build
@@ -117,3 +117,50 @@ if drm_xe
     )
 
 endif
+
+if vulkan.found()
+    vulkan_mock_lib = shared_library(
+        'vulkan_mock',
+        files('vulkan_mock.c')
+    )
+
+    test(
+        'test vulkan detection with invalid device',
+        vulkan_discrete,
+        args: ['NO_GPU'],
+        env: environment({'LD_PRELOAD': vulkan_mock_lib.full_path()}),
+        should_fail: true
+    )
+
+    test(
+        'test vulkan detection with integrated GPU',
+        vulkan_discrete,
+        args: ['IGPU'],
+        env: environment({'LD_PRELOAD': vulkan_mock_lib.full_path()}),
+        should_fail: true
+    )
+
+    test(
+        'test vulkan detection with discrete GPU',
+        vulkan_discrete,
+        args: ['DGPU'],
+        env: environment({'LD_PRELOAD': vulkan_mock_lib.full_path()}),
+        should_fail: false
+    )
+
+    test(
+        'test vulkan detection with virtual GPU',
+        vulkan_discrete,
+        args: ['VGPU'],
+        env: environment({'LD_PRELOAD': vulkan_mock_lib.full_path()}),
+        should_fail: true
+    )
+
+    test(
+        'test vulkan detection with CPU',
+        vulkan_discrete,
+        args: ['CPU'],
+        env: environment({'LD_PRELOAD': vulkan_mock_lib.full_path()}),
+        should_fail: true
+    )
+endif
diff --git a/tests/discrete-detection/vulkan_mock.c b/tests/discrete-detection/vulkan_mock.c
new file mode 100644
index 0000000..78a8b38
--- /dev/null
+++ b/tests/discrete-detection/vulkan_mock.c
@@ -0,0 +1,147 @@
+#define _DEFAULT_SOURCE
+
+#include <stdio.h>
+#include <string.h>
+#include <assert.h>
+#include <sys/stat.h>
+#include <sys/types.h>
+#include <vulkan/vulkan.h>
+
+enum {
+	IGPU,
+	DGPU,
+	VGPU,
+	CPU,
+
+	DEVICE_COUNT,
+};
+
+/* Mock open(2) so we can test multiple devices configurations */
+int
+open (const char *pathname,
+	  int         flags)
+{
+	if (!strcmp (pathname, "IGPU"))
+		return IGPU;
+	if (!strcmp (pathname, "DGPU"))
+		return DGPU;
+	if (!strcmp (pathname, "VGPU"))
+		return VGPU;
+	if (!strcmp (pathname, "CPU"))
+		return CPU;
+
+	return -1;
+}
+
+/* open64 may be used for large file support */
+int
+open64 (const char *pathname,
+		int         flags)
+{
+	return open (pathname, flags);
+}
+
+int
+fstat(int          fd,
+	  struct stat *statbuf)
+{
+	statbuf->st_rdev = fd;
+	statbuf->st_mode = S_IFCHR;
+
+	return 0;
+}
+
+VkResult
+vkCreateInstance(const VkInstanceCreateInfo*    pCreateInfo,
+				 const VkAllocationCallbacks*   pAllocator,
+				 VkInstance*                    pInstance)
+{
+	/* vkGetPhysicalDeviceProperties2 is provided by VK 1.1 */
+	assert(pCreateInfo->pApplicationInfo->apiVersion >= VK_API_VERSION_1_1);
+
+	return VK_SUCCESS;
+}
+
+VkResult
+vkEnumeratePhysicalDevices(VkInstance           instance,
+						   uint32_t*            pPhysicalDeviceCount,
+						   VkPhysicalDevice*    pPhysicalDevices)
+{
+	assert(pPhysicalDeviceCount);
+	*pPhysicalDeviceCount = DEVICE_COUNT;
+
+	if (pPhysicalDevices) {
+		for (uint32_t i = IGPU; i < DEVICE_COUNT; ++i) {
+			pPhysicalDevices[i] = (VkPhysicalDevice)i;
+		}
+	}
+
+	return VK_SUCCESS;
+}
+
+VkResult
+vkEnumerateDeviceExtensionProperties(VkPhysicalDevice           physicalDevice,
+									 const char*                pLayerName,
+									 uint32_t*                  pPropertyCount,
+									 VkExtensionProperties*     pProperties)
+{
+	assert(pPropertyCount);
+	*pPropertyCount = 1;
+
+	if (pProperties)
+		strncpy(pProperties[0].extensionName, "VK_EXT_physical_device_drm", VK_MAX_EXTENSION_NAME_SIZE);
+
+	return VK_SUCCESS;
+}
+
+void vkGetPhysicalDeviceProperties2(
+	VkPhysicalDevice                            physicalDevice,
+	VkPhysicalDeviceProperties2*                pProperties)
+{
+	int device_id = (int)physicalDevice;
+	VkPhysicalDeviceDrmPropertiesEXT *drm_properties;
+
+	switch (device_id) {
+		case IGPU:
+			pProperties->properties.deviceType = VK_PHYSICAL_DEVICE_TYPE_INTEGRATED_GPU;
+			break;
+
+		case DGPU:
+			pProperties->properties.deviceType = VK_PHYSICAL_DEVICE_TYPE_DISCRETE_GPU;
+			break;
+
+		case VGPU:
+			pProperties->properties.deviceType = VK_PHYSICAL_DEVICE_TYPE_VIRTUAL_GPU;
+			break;
+
+		case CPU:
+			pProperties->properties.deviceType = VK_PHYSICAL_DEVICE_TYPE_CPU;
+			break;
+
+		default:
+			assert(0);
+	}
+
+
+	VkBaseOutStructure *node = (VkBaseOutStructure*)pProperties->pNext;
+	while (node != NULL) {
+		switch (node->sType) {
+			case VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_DRM_PROPERTIES_EXT:
+				drm_properties = (VkPhysicalDeviceDrmPropertiesEXT*)node;
+
+				drm_properties->hasPrimary = VK_TRUE;
+				drm_properties->primaryMajor = 0;
+				drm_properties->primaryMinor = device_id;
+
+				drm_properties->hasRender = VK_TRUE;
+				drm_properties->renderMajor = 0;
+				drm_properties->renderMinor = device_id;
+
+				break;
+
+			default:
+				break;
+		}
+		node = node->pNext;
+	}
+}
\ No newline at end of file
